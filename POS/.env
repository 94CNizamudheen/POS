# Terminal identity — change per machine
VITE_TERMINAL_ID=POS-1

# Primary POS (this machine hosts the server): ws://127.0.0.1:3001
# Other POS machines: ws://192.168.1.X:3001 (primary POS LAN IP)
VITE_WS_URL=ws://127.0.0.1:3001

# TAURI_IS_PRIMARY_POS must be set in the OS environment (not here).
# On primary POS machine, run before launching: set TAURI_IS_PRIMARY_POS=1 (Windows cmd)
# The Rust WS server only starts when this env var is present at runtime.
